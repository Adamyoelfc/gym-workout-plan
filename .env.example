# Copy to .env and fill in. Used by docker-compose.

# --- Database (Postgres container) ---
POSTGRES_USER=shred
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=shred

# --- Auth ---
# Generate a strong secret, e.g.: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret

# --- AI (OpenRouter) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any OpenRouter model slug; default is Claude 3.5 Sonnet.
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Email (SMTP for verification emails) ---
# For production, use your SMTP provider (SendGrid, Mailgun, etc.)
# For development, leave empty to use console logging
EMAIL_FROM=noreply@gym-app.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- App ---
# Host port the app is exposed on (container always listens on 8080).
APP_PORT=8080
# Public URL of the deployment (used in OpenRouter referer header and email links).
PUBLIC_URL=http://localhost:8080
